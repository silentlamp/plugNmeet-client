# Portal Sign-In with Google / Apple (learner SPA only).
# Copy to `.env` or `.env.local` for local Vite. Production uses `.env.production`
# (or override via CI env). Meet room SPA does NOT read these.
#
# Values are baked into the portal login bundle at `pnpm build` (import.meta.env).
# They never go into Meet config.js.

# Google Web OAuth Client ID (GIS). Must also be in Java API GOOGLE_CLIENT_ID.
VITE_PORTAL_GOOGLE_CLIENT_ID=236923025711-u2pujicahnr29s5mej8lat0djpemj4i5.apps.googleusercontent.com

# Apple Services ID. Leave empty to hide the Apple button.
# Must also be in Java API APPLE_CLIENT_ID when enabled.
VITE_PORTAL_APPLE_CLIENT_ID=
